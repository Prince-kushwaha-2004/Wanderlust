<% layout("/layouts/boilerplate.ejs") %>
<div class="container py-5 text-center">
    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="alert alert-danger rounded-4 p-4 shadow-sm" role="alert">
                <i class="fa-solid fa-triangle-exclamation fs-1 mb-3"></i>
                <h4 class="fw-bold mb-2">Error Encountered</h4>
                <p class="mb-0 fs-6"><%=message%></p>
            </div>
            <a href="/listings" class="btn btn-primary-color rounded-pill px-4 mt-3">Back to Explore</a>
        </div>
    </div>
</div>

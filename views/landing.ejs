<% layout("/layouts/boilerplate.ejs") %>

<!-- Background Blob Accents -->
<div class="blob-accent-top-right"></div>
<div class="blob-accent-left"></div>

<!-- Hero Section (Jadoo Split Layout) -->
<div class="container hero-split-section py-5 mb-5">
  <div class="row align-items-center g-5">
    <!-- Hero Left: Text & CTA -->
    <div class="col-lg-6 text-start hero-left-content animate-fadeIn">
      <span class="sub-header-badge text-uppercase mb-3 d-inline-block">Best destinations around the world</span>
      <h1 class="display-3 fw-bold mb-3 hero-volkhov-title">
        Travel, <span class="highlight-underline">enjoy</span> and live a new and full life
      </h1>
      <p class="text-muted fs-6 lh-base mb-4 max-w-500">
        StayEasy connects you to unique, verified properties globally. Built for comfort, curated for quality, and engineered to make home-sharing smooth and worry-free.
      </p>
      <div class="d-flex align-items-center gap-4 flex-wrap">
        <a href="/listings" class="btn btn-primary-jadoo rounded-pill px-4 py-3 fw-semibold text-white shadow">
          Explore Stays
        </a>
        <a href="#" onclick="event.preventDefault(); Toastify({text: 'StayEasy Demo video is loading...', duration: 2500}).showToast();" class="d-flex align-items-center gap-2 text-decoration-none play-demo-btn">
          <span class="play-icon-circle d-flex align-items-center justify-content-center">
            <i class="fa-solid fa-play text-white fs-8"></i>
          </span>
          <span class="fw-semibold text-dark fs-7">Play Demo</span>
        </a>
      </div>
    </div>
    
    <!-- Hero Right: Illustration -->
    <div class="col-lg-6 hero-right-image position-relative text-center">
      <img src="/images/hero_image.png" class="img-fluid traveler-illustration z-2 position-relative" alt="Traveler Illustration">
      <!-- Decorative planes -->
      <div class="plane-icon position-absolute top-20 start-10 z-1"><i class="fa-solid fa-plane text-muted opacity-30 fs-4"></i></div>
      <div class="plane-icon position-absolute bottom-30 end-10 z-1"><i class="fa-solid fa-plane text-muted opacity-30 fs-5"></i></div>
    </div>
  </div>

  <!-- Unified Search Console Floating -->
  <div class="hero-search-box-floating mx-auto shadow-lg max-w-900 p-3 rounded-pill bg-white border mt-5">
    <form action="/listings" method="GET" class="row g-2 align-items-center m-0 w-100">
      <div class="col-md-5 text-start px-4">
        <label class="form-label mb-0 text-muted fs-8 fw-semibold uppercase"><i class="fa-solid fa-map-pin text-primary-color me-1"></i> Where to?</label>
        <input type="text" name="search" class="form-control border-0 shadow-none p-0 fs-6 text-dark" placeholder="Search destination, country...">
      </div>
      <div class="col-md-4 text-start px-4 border-start">
        <label class="form-label mb-0 text-muted fs-8 fw-semibold uppercase"><i class="fa-solid fa-hotel text-primary-color me-1"></i> Category</label>
        <select name="category" class="form-select border-0 shadow-none p-0 fs-6 text-dark bg-transparent">
          <option value="">All Stays</option>
          <option value="Trending">Trending</option>
          <option value="Rooms">Rooms</option>
          <option value="Iconic City">Iconic City</option>
          <option value="Mountains">Mountains</option>
          <option value="Castles">Castles</option>
          <option value="Arctic">Arctic</option>
          <option value="Camping">Camping</option>
          <option value="Farms">Farms</option>
          <option value="Amazing Pool">Amazing Pool</option>
          <option value="Beach">Beach</option>
          <option value="Island">Island</option>
          <option value="Foreign Trip">Foreign Trip</option>
        </select>
      </div>
      <div class="col-md-3 px-1 text-center">
        <button type="submit" class="btn btn-search-hero-jadoo w-100 py-3 rounded-pill d-flex align-items-center justify-content-center gap-2">
          <i class="fa-solid fa-magnifying-glass"></i>
          <span>Search</span>
        </button>
      </div>
    </form>
  </div>
</div>

<div class="container my-6">
  <!-- Section 2: Services -->
  <div class="text-center mb-5">
    <span class="text-uppercase text-muted fw-semibold tracking-wider fs-8">Category</span>
    <h2 class="fw-bold section-title-volkhov mt-1">We Offer Best Services</h2>
  </div>

  <div class="row g-4 row-cols-lg-4 row-cols-md-2 row-cols-1 mb-6">
    <div class="col">
      <div class="service-card p-4 text-center h-100">
        <div class="service-icon-wrapper mx-auto mb-4 d-flex align-items-center justify-content-center">
          <i class="fa-solid fa-house-circle-check text-primary-color fs-2"></i>
        </div>
        <h5 class="fw-bold mb-2">Verified Stays</h5>
        <p class="text-muted fs-7 mb-0">Every listing goes through a comprehensive inspection check to guarantee safe lodging.</p>
      </div>
    </div>
    <div class="col">
      <div class="service-card p-4 text-center h-100">
        <div class="service-icon-wrapper mx-auto mb-4 d-flex align-items-center justify-content-center">
          <i class="fa-solid fa-map-location-dot text-primary-color fs-2"></i>
        </div>
        <h5 class="fw-bold mb-2">Smart Map Pins</h5>
        <p class="text-muted fs-7 mb-0">Built-in Mapbox APIs guide you directly to coordinates with local surrounding details.</p>
      </div>
    </div>
    <div class="col">
      <div class="service-card p-4 text-center h-100">
        <div class="service-icon-wrapper mx-auto mb-4 d-flex align-items-center justify-content-center">
          <i class="fa-solid fa-comments text-primary-color fs-2"></i>
        </div>
        <h5 class="fw-bold mb-2">Real Reviews</h5>
        <p class="text-muted fs-7 mb-0">Authentic community reviews help you inspect and select neighborhood lodgings.</p>
      </div>
    </div>
    <div class="col">
      <div class="service-card p-4 text-center h-100">
        <div class="service-icon-wrapper mx-auto mb-4 d-flex align-items-center justify-content-center">
          <i class="fa-solid fa-headset text-primary-color fs-2"></i>
        </div>
        <h5 class="fw-bold mb-2">24/7 Support</h5>
        <p class="text-muted fs-7 mb-0">Our support coordinators manage checks, keys, and questions all day long.</p>
      </div>
    </div>
  </div>

  <!-- Section 3: Top Destinations -->
  <div class="d-flex justify-content-between align-items-end mb-4 pt-4">
    <div>
      <span class="text-uppercase text-muted fw-semibold tracking-wider fs-8">Top Selling</span>
      <h2 class="fw-bold section-title-volkhov mt-1">Top Destinations</h2>
    </div>
    <a href="/listings" class="btn btn-link-explore text-decoration-none fw-semibold">View All Stays <i class="fa-solid fa-arrow-right ms-1"></i></a>
  </div>

  <div class="row g-4 row-cols-lg-3 row-cols-md-2 row-cols-1 mb-6">
    <% if(featuredListings && featuredListings.length > 0) { %>
      <% featuredListings.forEach(listing => { %>
        <div class="col animate-hover-lift">
          <div class="card listing-card-premium border-0 shadow-sm rounded-4 position-relative overflow-hidden bg-white h-100">
            <span class="badge position-absolute top-0 end-0 m-3 z-3 bg-glass-tag px-3 py-2 text-dark fw-semibold"><i class="fa-solid fa-star text-warning me-1"></i><%= listing.category %></span>
            <div class="card-img-wrapper position-relative overflow-hidden" style="height: 250px;">
              <img src="<%= listing.image.url %>" class="w-100 h-100 object-fit-cover listing-img-card" alt="<%= listing.title %>">
              <div class="img-overlay-hover d-flex align-items-center justify-content-center">
                <a href="/listings/<%= listing._id %>" class="btn btn-glass-view">View Stay</a>
              </div>
            </div>
            <div class="card-body p-4">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="card-title fw-bold text-truncate mb-0" style="max-width: 70%;"><%= listing.title %></h5>
                <span class="text-dark fw-bold fs-6">&#8377; <%= listing.price.toLocaleString("en-IN") %> <span class="text-muted fs-8 font-normal">/night</span></span>
              </div>
              <div class="d-flex justify-content-between align-items-center pt-3 border-top text-muted">
                <span class="fs-7"><i class="fa-solid fa-location-dot me-1 text-primary-color"></i><%= listing.location %>, <%= listing.country %></span>
                <span class="fs-7"><i class="fa-regular fa-compass me-1 text-accent-color"></i>Explore Neighbours</span>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="col-12 text-center py-5">
        <p class="text-muted">No featured listings available. Explore all properties inside listing page.</p>
      </div>
    <% } %>
  </div>

  <!-- Section 4: Easy Steps (Jadoo Layout) -->
  <div class="row align-items-center g-5 py-5 mb-5">
    <div class="col-lg-6 text-start">
      <span class="text-uppercase text-muted fw-semibold tracking-wider fs-8">Easy and Fast</span>
      <h2 class="fw-bold section-title-volkhov mt-2 mb-4">Book your next stay in 3 easy steps</h2>
      
      <div class="d-flex flex-column gap-4">
        <!-- Step 1 -->
        <div class="d-flex align-items-start gap-3">
          <div class="step-icon-bg bg-light-warning rounded-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; flex-shrink: 0;">
            <i class="fa-solid fa-location-arrow text-warning fs-5"></i>
          </div>
          <div>
            <h6 class="fw-bold mb-1 text-dark">Choose Destination</h5>
            <p class="text-muted fs-7 mb-0">Browse through hundreds of properties from over 20+ exotic categories.</p>
          </div>
        </div>
        <!-- Step 2 -->
        <div class="d-flex align-items-start gap-3">
          <div class="step-icon-bg bg-light-accent rounded-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; flex-shrink: 0;">
            <i class="fa-solid fa-wallet text-accent-color fs-5"></i>
          </div>
          <div>
            <h6 class="fw-bold mb-1 text-dark">Make Secure Payment</h5>
            <p class="text-muted fs-7 mb-0">Enter check-in dates and complete secure payment with 100% price protection.</p>
          </div>
        </div>
        <!-- Step 3 -->
        <div class="d-flex align-items-start gap-3">
          <div class="step-icon-bg bg-light-primary rounded-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; flex-shrink: 0;">
            <i class="fa-solid fa-house-laptop text-primary-color fs-5"></i>
          </div>
          <div>
            <h6 class="fw-bold mb-1 text-dark">Reach Airport on Selected Date</h5>
            <p class="text-muted fs-7 mb-0">Receive instructions from your verified host and check-in to your comfortable lodging.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Easy Steps Right Column: Trip Mock Card -->
    <div class="col-lg-6 position-relative d-flex justify-content-center align-items-center">
      <div class="step-mock-card shadow-lg p-4 rounded-4 bg-white border position-relative z-2 animate-hover-lift" style="width: 100%; max-width: 380px;">
        <div class="mock-card-img-wrapper rounded-3 overflow-hidden mb-3" style="height: 180px;">
          <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80" class="w-100 h-100 object-fit-cover" alt="Greece Trip">
        </div>
        <h6 class="fw-bold text-dark mb-2">Trip to Greece</h6>
        <p class="text-muted fs-8 mb-3">14-29 June | by StayEasy Host</p>
        
        <div class="d-flex gap-2 mb-3">
          <span class="badge bg-light text-dark border p-2 rounded-circle"><i class="fa-solid fa-leaf text-muted fs-8"></i></span>
          <span class="badge bg-light text-dark border p-2 rounded-circle"><i class="fa-solid fa-map text-muted fs-8"></i></span>
          <span class="badge bg-light text-dark border p-2 rounded-circle"><i class="fa-regular fa-paper-plane text-muted fs-8"></i></span>
        </div>

        <div class="d-flex justify-content-between align-items-center pt-2">
          <span class="text-muted fs-8"><i class="fa-regular fa-building me-1"></i>24 people going</span>
          <i class="fa-regular fa-heart text-danger fs-6 cursor-pointer"></i>
        </div>

        <!-- Floating Ongoing card -->
        <div class="floating-mock-mini-card shadow-lg p-3 rounded-4 bg-white border position-absolute z-3 d-flex align-items-center gap-3">
          <div class="avatar bg-primary-light text-primary-color rounded-circle d-flex align-items-center justify-content-center fw-bold fs-7" style="width: 40px; height: 40px; flex-shrink: 0;">
            RO
          </div>
          <div>
            <span class="text-muted fs-9 d-block mb-1 text-uppercase fw-semibold tracking-wider">Ongoing</span>
            <h6 class="fw-bold mb-1 text-dark fs-8">Trip to Rome</h6>
            <span class="text-primary-color fw-bold fs-8">40% completed</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Section 5: Testimonials -->
  <div class="my-6">
    <div class="text-center mb-5">
      <span class="text-uppercase text-muted fw-semibold tracking-wider fs-8">Testimonials</span>
      <h2 class="fw-bold section-title-volkhov mt-1">What people say about Us.</h2>
    </div>
    <div class="row g-4 justify-content-center">
      <div class="col-md-5">
        <div class="testimonial-card-jadoo p-4 rounded-4 bg-white border shadow-sm position-relative">
          <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?ixlib=rb-4.0.3&auto=format&fit=crop&w=150&q=80" alt="Avatar" class="avatar-testimonial rounded-circle shadow border position-absolute">
          <p class="text-muted fs-7 italic mb-4 mt-3">
            "The beachfront villa was exactly as pictured! The check-in details sent by StayEasy host made the transition smooth. Customer support was incredibly active!"
          </p>
          <h6 class="fw-bold mb-0 text-dark">Emily Morrison</h6>
          <span class="text-muted fs-8">Travel Blogger</span>
        </div>
      </div>
      <div class="col-md-5 offset-md-1">
        <div class="testimonial-card-jadoo p-4 rounded-4 bg-white border shadow-sm position-relative">
          <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=150&q=80" alt="Avatar" class="avatar-testimonial rounded-circle shadow border position-absolute">
          <p class="text-muted fs-7 italic mb-4 mt-3">
            "StayEasy has completely transformed the user experience! Category filtering and search parameters allow me to book comfortable lodgings inside 2 minutes."
          </p>
          <h6 class="fw-bold mb-0 text-dark">Rohan Kapoor</h6>
          <span class="text-muted fs-8">Software Engineer</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Section 6: Brand Logos -->
  <div class="row g-4 align-items-center justify-content-center py-5 border-top border-bottom my-6 opacity-60">
    <div class="col-md-2 col-6 text-center"><span class="fs-4 fw-bold font-logo text-muted">axon</span></div>
    <div class="col-md-2 col-6 text-center"><span class="fs-4 fw-bold font-logo text-muted">jetstar</span></div>
    <div class="col-md-2 col-6 text-center"><span class="fs-4 fw-bold font-logo text-muted">Expedia</span></div>
    <div class="col-md-2 col-6 text-center"><span class="fs-4 fw-bold font-logo text-muted">QANTAS</span></div>
    <div class="col-md-2 col-6 text-center"><span class="fs-4 fw-bold font-logo text-muted">alitalia</span></div>
  </div>

  <!-- Section 7: Newsletter Subscribe -->
  <div class="newsletter-jadoo-wrapper rounded-4 my-6 p-5 text-center position-relative overflow-hidden shadow">
    <div class="decor-circle-top"></div>
    <div class="decor-circle-bottom"></div>
    
    <div class="position-relative z-3 max-w-600 mx-auto py-4">
      <h3 class="fw-bold mb-3 fs-3 text-secondary-accent">Subscribe to get information, latest news and other interesting offers about Cobham</h3>
      <form onsubmit="event.preventDefault(); Toastify({text: 'Subscribed successfully! Check your email.', duration: 3000, style: {background: 'linear-gradient(135deg, #10b981 0%, #059669 100%)'}}).showToast();" class="row g-2 justify-content-center mt-4">
        <div class="col-md-8">
          <div class="input-group">
            <span class="input-group-text bg-white border-end-0 rounded-start-pill px-3"><i class="fa-regular fa-envelope text-muted"></i></span>
            <input type="email" class="form-control border-start-0 rounded-end-pill py-3 px-2 fs-7" placeholder="Your email address" required>
          </div>
        </div>
        <div class="col-md-4">
          <button type="submit" class="btn btn-primary-jadoo w-100 py-3 rounded-pill fw-semibold text-white shadow-sm">Subscribe</button>
        </div>
      </form>
    </div>
  </div>
</div>
